# OAuth2 Configuration for Microsoft and Kanidm
# Copy this file to .env and fill in your credentials

# Server Configuration
PORT=8000
HOST=0.0.0.0
JWT_SECRET_KEY=your-very-secure-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Internal Endpoint Authentication (Optional but recommended)
# Set a strong API key to protect the /internal endpoint
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY=your-strong-api-key-for-internal-endpoint
INTERNAL_API_KEY_HEADER=X-Internal-API-Key

# Nginx Configuration
# IP address allowed to access /internal* endpoints through nginx
# This is used by nginx to allow access from the log source IP
# Leave empty to block all external access (relying only on API key)
INTERNAL_ALLOWED_IP=

# ============================================
# Microsoft Entra ID (Azure AD) OAuth2 Configuration
# ============================================
# Register your app at: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps/NewApplication
MICROSOFT_CLIENT_ID=your-microsoft-azure-ad-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-azure-ad-client-secret
# Optional: Specify tenant ID for single-tenant apps
# MICROSOFT_TENANT_ID=your-tenant-id

# ============================================
# Kanidm OIDC Configuration
# ============================================
# Configure these to match your Kanidm server
KANIDM_CLIENT_ID=your-kanidm-client-id
KANIDM_CLIENT_SECRET=your-kanidm-client-secret
KANIDM_AUTHORIZE_URL=https://your-kanidm-server.example.com/oauth2/authorize
KANIDM_TOKEN_URL=https://your-kanidm-server.example.com/oauth2/token
KANIDM_JWKS_URI=https://your-kanidm-server.example.com/oauth2/jwks
KANIDM_ISSUER=https://your-kanidm-server.example.com

# ============================================
# Deployment Notes
# ============================================
# For production deployment:
# 1. Always use HTTPS
# 2. Set strong JWT_SECRET_KEY (32+ random characters)
# 3. Configure reverse proxy to only expose /public* and /auth* paths
# 4. Keep /internal* endpoints internal-only (not accessible from internet)
# 5. Set appropriate CORS origins
