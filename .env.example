# ---- Server ----
HOST=0.0.0.0
PORT=8000

# ---- Cache ----
CACHE_MAX_EVENTS=200

# ---- Ingest authentication ----
# Leave empty to allow all sources (development only)
INTERNAL_API_KEY=
INTERNAL_API_KEY_HEADER=X-Internal-API-Key

# ---- Stream authentication ----
# Set to true to require OAuth2 for the public stream
REQUIRE_AUTH=false

# ---- Session & JWT ----
SESSION_SECRET=change-me-in-production
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ---- Microsoft Entra ID (optional) ----
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ---- Kanidm OIDC (optional) ----
KANIDM_CLIENT_ID=
KANIDM_CLIENT_SECRET=
KANIDM_BASE_URL=https://kanidm.example.com
