# Docker ignore file
# Files and directories to exclude from Docker build context

# Python
__pycache__
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.env
.venv
env/
venv/
ENV/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Testing
.tox/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.mypy_cache/

# Docker
Dockerfile*
docker-compose*
.docker/

# Git
.git/
.gitignore

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Local configuration
.env
.env.local
.env.*.local

# SSL certificates (mounted as volumes, not copied)
ssl/

# Nginx
nginx/

# Static files (mounted as volumes)
static/
templates/

# Documentation
*.md
